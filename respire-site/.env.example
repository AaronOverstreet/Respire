# Production: respirebreathwork.com — Vercel: Framework Preset “Vite”, Root Directory `respire-site`, Output `dist` (default).
# Server routes live in `api/` → /api/contact and /api/newsletter.
# Set these in Vercel → Project → Settings → Environment Variables (never commit real values).

# Resend (contact form only) — https://resend.com
RESEND_API_KEY=
# Use a verified sending domain in Resend, e.g. Respire <hello@yourdomain.com>
RESEND_FROM_EMAIL=
# Inbox that receives contact form submissions
CONTACT_INBOX_EMAIL=

# Mailchimp (newsletter cards only) — Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
