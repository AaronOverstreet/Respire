# Production: www.respirebreathwork.com — Vercel: Framework Preset “Vite”, Root Directory `respire-site`, Output `dist` (default).
# Server routes live in `api/` → /api/contact and /api/newsletter.
# Set these in Vercel → Project → Settings → Environment Variables (never commit real values).

# Resend (contact form only) — API host is https://api.resend.com (do not set RESEND_BASE_URL unless Resend tells you to).
RESEND_API_KEY=
# Must use a domain you verified in Resend → Domains (otherwise only test sends to your own inbox work; visitor confirmations fail).
RESEND_FROM_EMAIL=
# Inbox that receives contact form submissions
CONTACT_INBOX_EMAIL=

# Mailchimp (newsletter cards only) — Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
