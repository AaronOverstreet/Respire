# Production: www.respirebreathwork.com — Vercel: Framework Preset “Vite”, Root Directory `respire-site`, Output `dist` (default).
# Server routes live in `api/` → /api/contact and /api/newsletter.
# Set these in Vercel → Project → Settings → Environment Variables (never commit real values).

# Mailchimp Transactional (contact form) — key from Transactional → Settings → SMTP & API Info (not the same as Marketing API key).
MAILCHIMP_TRANSACTIONAL_API_KEY=
# From address on a domain you verified with DKIM in Transactional (Sending Defaults / verified domains).
MAILCHIMP_TRANSACTIONAL_FROM_EMAIL=
# Optional display name for From (defaults to Respire).
# MAILCHIMP_TRANSACTIONAL_FROM_NAME=
# Inbox that receives contact form submissions
CONTACT_INBOX_EMAIL=

# Mailchimp Marketing API (newsletter) — Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
