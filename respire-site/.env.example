# Resend (contact form only) — https://resend.com
RESEND_API_KEY=
# Must be from a domain you verified in Resend (e.g. "Respire <hello@yourdomain.com>")
RESEND_FROM_EMAIL=
# Where inbound contact messages should be delivered
CONTACT_INBOX_EMAIL=

# Mailchimp (newsletter cards only) — Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
